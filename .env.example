# Copy to .env and fill in your values.
#
# Only keys, URLs, and provider choice belong here. Performance tuning lives in
# search_agent/tuning.py (constants).

# ── Required ────────────────────────────────────────────────────────────────
# LLM (OpenAI-compatible, e.g. OpenRouter)
LLM_API_KEY=your_key_here

# Optional: higher GitHub REST API rate limits when fetching README / latest release by URL
# GITHUB_TOKEN=

# Web search (Brave Search API — primary backend when SEARCH_PROVIDER=brave)
# https://brave.com/search/api/
BRAVE_API_KEY=your_brave_subscription_token_here

# ── Search ───────────────────────────────────────────────────────────────────
# SEARCH_PROVIDER=brave
# SEARCH_PROVIDER_OVERRIDE=ddgs
# When SEARCH_PROVIDER cannot be changed in a shared .env, set SEARCH_PROVIDER_OVERRIDE;
# or per run: search-agent -S ddgs -q "..."

# BRAVE_BASE_URL=https://api.search.brave.com
# BRAVE_COUNTRY=US
# BRAVE_SAFESEARCH=moderate
# BRAVE_GOGGLES=

# SEARCH_BACKEND_FALLBACK_DELAY_SEC=1.0
# BRAVE_SEARCH_FALLBACK=true

# DuckDuckGo when SEARCH_PROVIDER=ddgs (per-profile overrides also in config/profiles.py)
# DDGS_REGION=wt-wt
# DDGS_SAFESEARCH=moderate
# DDGS_TIMEOUT=15

# ── LLM optional ─────────────────────────────────────────────────────────────
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=qwen/qwen3.5-35b-a3b
# LLM_PROVIDER=
# LLM_MAX_TOKENS=8192
# LLM_HTTP_REFERER=https://github.com/local/search-agent

# ── Runtime ──────────────────────────────────────────────────────────────────
# DEFAULT_PROFILE=web
# AGENT_RECEIPTS_DIR=
# Optional: max chars per extracted page (overrides search_agent.tuning.EXTRACT_MAX_CHARS).
# EXTRACT_MAX_CHARS=4000
# Optional LLM output caps for llm_tasks (still bounded by LLM_MAX_TOKENS).
# COMPOSE_ANSWER_MAX_TOKENS=1600
# RAG_ANALYSIS_MAX_TOKENS=1400
# CLAIM_DECOMPOSE_MAX_TOKENS=500
# VERIFY_CLAIM_MAX_TOKENS=700
# TIME_NORMALIZE_MAX_TOKENS=120

# ── Logfire (optional; token only — other options in search_agent/tuning.py) ─
# LOGFIRE_TOKEN=
