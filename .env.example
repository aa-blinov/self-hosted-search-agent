# Copy to .env and fill in your values

# ── Required ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Search backend ───────────────────────────────────────────────────────────
# jina     — DDG + Jina content extraction. Free, no key. DEFAULT.
# ddg      — DuckDuckGo snippets only. Free, shallow context.
# searxng  — Self-hosted metasearch (Google+Bing+DDG+Yandex). Best free for CIS/RU.
#            Requires: docker compose up -d  (already done if you ran setup)
# yandex   — Yandex XML API. Best CIS/RU. Free registration: https://yandex.ru/dev/xml/
# tavily   — Best overall quality. 1K free/month: https://tavily.com
SEARCH_BACKEND=jina

# How many URLs to fetch full content for (jina backend, default: 3)
# JINA_FETCH_TOP_N=3

# SearXNG instance URL (default: http://localhost:8888)
# SEARXNG_URL=http://localhost:8888
# SEARXNG_LANGUAGE=auto

# Yandex (requires free registration)
# SEARCH_BACKEND=yandex
# YANDEX_USER=your_yandex_login
# YANDEX_SEARCH_KEY=your_yandex_xml_key

# Tavily (requires free API key)
# SEARCH_BACKEND=tavily
# TAVILY_API_KEY=your_tavily_key_here

# ── HTML extractor ───────────────────────────────────────────────────────────
# jina_api       — r.jina.ai (free, ReaderLM-v2 on Jina servers). DEFAULT.
# readerlm_local — jinaai/ReaderLM-v2 running locally (2GB, needs transformers+torch).
#                  pip install transformers torch
HTML_EXTRACTOR=jina_api

# Max chars to keep per extracted page (default: 2000)
# EXTRACT_MAX_CHARS=2000

# ── EvidenceLoop ─────────────────────────────────────────────────────────────
# Max search iterations if context quality is weak (default: 2)
# EVIDENCE_LOOP_ITERATIONS=2
# Min chars to consider context sufficient (default: 800)
# EVIDENCE_LOOP_MIN_CHARS=800

# ── Model ────────────────────────────────────────────────────────────────────
# OPENROUTER_MODEL=qwen/qwen3-8b
