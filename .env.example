# Copy to .env and fill in your values.
#
# Names: snake_case field in search_agent/settings.py → UPPER_SNAKE (e.g. extract_max_chars → EXTRACT_MAX_CHARS).

# ── Required ────────────────────────────────────────────────────────────────
# LLM (OpenAI-compatible, e.g. OpenRouter)
LLM_API_KEY=your_key_here

# Web search (Brave Search API — primary backend when SEARCH_PROVIDER=brave)
# https://brave.com/search/api/
BRAVE_API_KEY=your_brave_subscription_token_here

# ── Search ───────────────────────────────────────────────────────────────────
# SEARCH_PROVIDER=brave
# SEARCH_PROVIDER_OVERRIDE=ddgs
# When SEARCH_PROVIDER cannot be changed in a shared .env, set SEARCH_PROVIDER_OVERRIDE;
# or per run: search-agent -S ddgs -q "..."

# BRAVE_BASE_URL=https://api.search.brave.com
# BRAVE_COUNTRY=US
# BRAVE_SAFESEARCH=moderate
# BRAVE_GOGGLES=

# SEARCH_BACKEND_FALLBACK_DELAY_SEC=1.0
# BRAVE_SEARCH_FALLBACK=true

# DuckDuckGo when SEARCH_PROVIDER=ddgs (per-profile overrides also in config/profiles.py)
# DDGS_REGION=wt-wt
# DDGS_SAFESEARCH=moderate
# DDGS_TIMEOUT=15

# ── LLM optional ─────────────────────────────────────────────────────────────
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=qwen/qwen3.5-35b-a3b
# LLM_PROVIDER=
# LLM_MAX_TOKENS=8192
# LLM_HTTP_REFERER=https://github.com/local/search-agent

# ── Runtime ──────────────────────────────────────────────────────────────────
# DEFAULT_PROFILE=web
# AGENT_RECEIPTS_DIR=

# ── Logfire (optional) ───────────────────────────────────────────────────────
# LOGFIRE_TOKEN=
# LOGFIRE_SERVICE_NAME=self-hosted-search-agent
# LOGFIRE_ENVIRONMENT=development
# LOGFIRE_SEND_TO_LOGFIRE=if-token-present
# LOGFIRE_LOCAL=true
# LOGFIRE_CONSOLE=false
# LOGFIRE_INCLUDE_CONTENT=false

# ── Extractor / fetch ────────────────────────────────────────────────────────
# SHALLOW_FETCH_TIMEOUT=8
# EXTRACT_MAX_CHARS=3000
# CRAWL4AI_TIMEOUT=25
# CRAWL4AI_DELAY_BEFORE_HTML=1.0
# CRAWL4AI_PREFER_RAW=false
# FETCH_TRY_HTTP_FIRST=false
# FETCH_HTTP_MIN_CHARS=1200
# FETCH_SHALLOW_CONCURRENCY=8
# FETCH_DEEP_CONCURRENCY=2

# ── Agent loop ───────────────────────────────────────────────────────────────
# AGENT_MAX_CLAIM_ITERATIONS=3
# AGENT_MAX_QUERY_VARIANTS=6
# AGENT_MAX_REFINE_VARIANTS=12
# AGENT_FETCH_TOP_N=4
# AGENT_PASSAGE_TOP_K=8
# SERP_GATE_MIN_URLS=15
# SERP_GATE_MAX_URLS=30
# AGENT_SNIPPET_FALLBACK_DOCS=2
# SHALLOW_FETCH_SHORT_LIMIT=8
# SHALLOW_FETCH_TARGETED_LIMIT=12
# SHALLOW_FETCH_ITERATIVE_LIMIT=15
# DEEP_FETCH_SHORT_LIMIT=2
# DEEP_FETCH_TARGETED_LIMIT=3
# DEEP_FETCH_ITERATIVE_LIMIT=4
# CHEAP_PASSAGE_LIMIT=12

# ── Evaluation ───────────────────────────────────────────────────────────────
# EVAL_CASE_DELAY_SEC=2.0
